DATABASE_URL=sqlite:///./backend/studypilot.db
JWT_SECRET=replace-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
AUTO_CREATE_TABLES=true
SYNC_DOCUMENT_PROCESSING=false
UPLOAD_DIR=./backend/storage/uploads
PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGE=chi_sim+eng
PDF_OCR_DPI=220
PDF_OCR_MIN_TEXT_CHARS=24
EMBEDDING_DIMENSION=1024

# LLM provider (mock works without credentials). For remote chat with local embeddings:
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_CHAT_MODEL=
LLM_EMBEDDING_MODEL=
LLM_EMBEDDING_BATCH_SIZE=20
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

