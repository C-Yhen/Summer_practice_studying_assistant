# Application
APP_ENV=development
APP_NAME=Smart Learning Assistant
API_V1_PREFIX=/api/v1
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
AUTO_CREATE_TABLES=true
SYNC_DOCUMENT_PROCESSING=false

# PostgreSQL + pgvector
POSTGRES_DB=smart_learning
POSTGRES_USER=smart_learning
POSTGRES_PASSWORD=smart_learning_dev
DATABASE_URL=postgresql+psycopg://smart_learning:smart_learning_dev@postgres:5432/smart_learning
EMBEDDING_DIMENSION=1024

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# File storage
UPLOAD_DIR=/app/backend/storage/uploads
MAX_UPLOAD_BYTES=104857600

# LLM provider (mock works without credentials)
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_CHAT_MODEL=
LLM_EMBEDDING_MODEL=

# MCP server
BACKEND_BASE_URL=http://backend:8000/api/v1
MCP_CONFIRMATION_SECRET=change-me-too
MCP_CONFIRMATION_TTL_SECONDS=300
MCP_SERVICE_TOKEN=

# Frontend
VITE_API_BASE_URL=/api/v1
VITE_WS_URL=/api/v1/ws/async-tasks
VITE_ENABLE_MOCK=false
